# Backend environment variables
# Copy this file to .env and fill in your real values

PORT=5000

# MongoDB — use Atlas connection string for production
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/speak2design
MONGODB_URI=mongodb://127.0.0.1:27017/speak2design

# JWT Secret — use a long random string in production (min 32 chars)
JWT_SECRET=replace_this_with_a_long_random_secret_key_minimum_32_chars

# Google Gemini API Key — get from https://aistudio.google.com/app/apikey
# Used for both audio transcription and UI generation (gemini-2.0-flash).
GEMINI_API_KEY=Your_Google_Gemini_API_Key_Here

# Frontend origin for CORS (your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Stripe TEST secret key (optional) — get from https://dashboard.stripe.com/test/apikeys
# If omitted, marketplace purchases fall back to a simulated payment.
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_TEST_SECRET_KEY

# This backend's own public URL — used to build OAuth callback URLs.
# Locally http://127.0.0.1:5000 ; in production your Render URL.
BACKEND_URL=http://127.0.0.1:5000

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# If a provider's pair is omitted, its login button shows "not configured".
# Google: https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: <BACKEND_URL>/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers (New OAuth App)
#   Authorization callback URL: <BACKEND_URL>/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── SMTP for password-reset emails (optional) ────────────────────────────────
# If omitted, the reset link is returned in the API response (dev/demo mode).
# Gmail example: host smtp.gmail.com, port 587, user=your address, pass=App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Speak2Design <no-reply@speak2design.app>

# Node environment
NODE_ENV=production
