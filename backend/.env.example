# ── Server ────────────────────────────────────────────────────────────────────
PORT=

# ── Database ──────────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/speak2design
MONGODB_URI=

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE=7d

# ── AI Provider (Groq) ────────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
# Used for: Whisper audio transcription + LLaMA UI generation + NLP parsing
GROQ_API_KEY=
AI_PROVIDER=groq

# ── Stripe (test mode) ────────────────────────────────────────────────────────
# Secret key: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook secret: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=

# ── AWS S3 (optional) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ── OAuth (optional) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── SMTP (password reset emails) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=
BACKEND_URL=

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
