# Backend environment variables
# Copy this file to .env and fill in your real values

PORT=5000

# MongoDB — use Atlas connection string for production
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/speak2design
MONGODB_URI=mongodb://127.0.0.1:27017/speak2design

# JWT Secret — use a long random string in production (min 32 chars)
JWT_SECRET=replace_this_with_a_long_random_secret_key_minimum_32_chars

# Google Gemini API Key — get from https://aistudio.google.com/app/apikey
# Used for both audio transcription and UI generation (gemini-2.0-flash).
GEMINI_API_KEY=Your_Google_Gemini_API_Key_Here

# Frontend origin for CORS (your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Stripe TEST secret key (optional) — get from https://dashboard.stripe.com/test/apikeys
# If omitted, marketplace purchases fall back to a simulated payment.
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_TEST_SECRET_KEY

# Node environment
NODE_ENV=production
