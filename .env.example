# Frontend environment variables
# Copy this file to .env and fill in your values

# Backend API URL (change to your Render/Railway URL after deployment)
VITE_API_URL=http://127.0.0.1:5000

# Stripe TEST publishable key (optional) — get from https://dashboard.stripe.com/test/apikeys
# If omitted, checkout uses a simulated payment instead of Stripe Elements.
VITE_STRIPE_PK=pk_test_YOUR_STRIPE_TEST_PUBLISHABLE_KEY_HERE
